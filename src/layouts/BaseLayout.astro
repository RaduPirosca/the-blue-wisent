---
import ThemeSelect from "@components/ThemeSelect.astro";
import { siteConfig } from "@config/site";
import { withBase } from "@lib/paths";
import "@styles/global.css";

const {
  title = siteConfig.name,
  description = siteConfig.description,
} = Astro.props;

const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const visibleNavItems = siteConfig.nav.filter((item) => item.visible);
const themeInitScript = `
  (() => {
    const key = "blue-wisent-theme";
    const stored = localStorage.getItem(key);
    const choice = stored === "light" || stored === "dark" || stored === "system" ? stored : "system";
    const resolved = choice === "system" && matchMedia("(prefers-color-scheme: dark)").matches ? "dark" : choice === "dark" ? "dark" : "light";
    document.documentElement.dataset.themeChoice = choice;
    document.documentElement.dataset.theme = resolved;
  })();
`;
---

<!doctype html>
<html lang="en" data-theme="light" data-theme-choice="system">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <script is:inline set:html={themeInitScript}></script>
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("icons/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("icons/apple-touch-icon.png")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase("")}>
          <img class="brand-mark" src={withBase("icons/blue-wisent-mark-outlined.png")} alt="" width="48" height="48" />
          <span class="brand-name">The Blue Wisent</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {visibleNavItems.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
        </nav>
        <ThemeSelect />
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>{siteConfig.name}</span>
        <span>{siteConfig.copy.footer}</span>
      </footer>
    </div>
    <script>
      import "@scripts/theme";
      import "@scripts/footnotes";
    </script>
  </body>
</html>
