---
import { siteConfig } from "@config/site";
import { withBase } from "@lib/paths";
import "@styles/global.css";

const {
  title = siteConfig.name,
  description = siteConfig.description,
} = Astro.props;

const pageTitle = title === siteConfig.name ? title : `${title} | ${siteConfig.name}`;
const visibleNavItems = siteConfig.nav.filter((item) => item.visible);
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/png" sizes="32x32" href={withBase("icons/favicon-32.png")} />
    <link rel="apple-touch-icon" href={withBase("icons/apple-touch-icon.png")} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={withBase("")}>
          <img class="brand-mark" src={withBase("icons/blue-wisent-mark.png")} alt="" width="48" height="48" />
          <span class="brand-name">The Blue Wisent</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          {visibleNavItems.map((item) => <a href={withBase(item.href)}>{item.label}</a>)}
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>{siteConfig.name}</span>
        <span>{siteConfig.copy.footer}</span>
      </footer>
    </div>
  </body>
</html>
