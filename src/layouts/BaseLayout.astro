---
import WisentMark from "@components/WisentMark.astro";
import "@styles/global.css";

const {
  title = "The Blue Wisent",
  description = "A personal blog and experiment garden.",
} = Astro.props;

const pageTitle = title === "The Blue Wisent" ? title : `${title} | The Blue Wisent`;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{pageTitle}</title>
  </head>
  <body>
    <div class="site-shell">
      <header class="site-header">
        <a class="brand" href={base}>
          <WisentMark />
          <span class="brand-name">The Blue Wisent</span>
        </a>
        <nav class="site-nav" aria-label="Main navigation">
          <a href={`${base}writing/`}>Writing</a>
          <a href={`${base}experiments/`}>Experiments</a>
          <a href={`${base}about/`}>About</a>
        </nav>
      </header>
      <main class="site-main">
        <slot />
      </main>
      <footer class="site-footer">
        <span>The Blue Wisent</span>
        <span>&lt;BLABLA-FOOTER-NOTE-TO-BE-FILLED&gt;</span>
      </footer>
    </div>
  </body>
</html>
