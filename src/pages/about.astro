---
import { siteConfig } from "@config/site";
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="About" description="About The Blue Wisent.">
  <article class="article">
    <header class="article-header">
      <p class="kicker">About</p>
      <h1>The Blue Wisent</h1>
      <p class="lede">
        {siteConfig.copy.aboutLede}
      </p>
    </header>

    <h2>What Lives Here</h2>
    <p>
      {siteConfig.copy.aboutWhatLivesHere}
    </p>

    <h2>Elsewhere</h2>
    <p>
      {siteConfig.copy.aboutElsewhere}
    </p>
  </article>
</BaseLayout>
