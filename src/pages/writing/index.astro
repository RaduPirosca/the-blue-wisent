---
import { getCollection } from "astro:content";
import { siteConfig } from "@config/site";
import BaseLayout from "@layouts/BaseLayout.astro";
import { withBase } from "@lib/paths";

const writing = (await getCollection("writing"))
  .filter((entry) => !entry.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());

---

<BaseLayout title="Writing" description="Essays and notes from The Blue Wisent.">
  <section>
    <div class="section-head">
      <div>
        <p class="kicker">Archive</p>
        <h1>Writing</h1>
      </div>
      <p>{siteConfig.copy.writingArchive}</p>
    </div>
    <div class="grid">
      {writing.map((entry) => (
        <article class="card">
          <p class="meta">{entry.data.date.toLocaleDateString("en", { year: "numeric", month: "long", day: "numeric" })}</p>
          <h3><a href={withBase(`writing/${entry.slug}/`)}>{entry.data.title}</a></h3>
          {entry.data.subtitle && <p class="card-subtitle">{entry.data.subtitle}</p>}
          <p>{entry.data.description}</p>
          {entry.data.tags.length > 0 && (
            <ul class="tag-list" aria-label="Tags">
              {entry.data.tags.map((tag) => <li>{tag}</li>)}
            </ul>
          )}
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
