---
import TitleSearch from "@components/TitleSearch.astro";
import { siteConfig } from "@config/site";
import BaseLayout from "@layouts/BaseLayout.astro";
import { getExperiments, getPublishedPosts, getSearchItems, ITEMS_PER_PAGE } from "@lib/content";
import { withBase } from "@lib/paths";

const allPosts = await getPublishedPosts();
const allExperiments = await getExperiments();
const isNavVisible = (href: string) => siteConfig.nav.some((item) => item.href === href && item.visible);
const showExperiments = isNavVisible("experiments/");
const visibleExperiments = showExperiments ? allExperiments : [];

const posts = allPosts.slice(0, ITEMS_PER_PAGE);
const experiments = visibleExperiments.slice(0, ITEMS_PER_PAGE);
const searchItems = getSearchItems({ posts: allPosts, experiments: visibleExperiments });
const searchLabel = showExperiments ? "Search posts and experiments by title" : "Search posts by title";
---

<BaseLayout>
  <section class="hero">
    <div>
      <p class="kicker">{siteConfig.copy.homeKicker}</p>
      <h1>{siteConfig.name}</h1>
    </div>
    <div class="hero-panel">
      <p class="lede">
        {siteConfig.copy.homeIntro}
      </p>
    </div>
  </section>

  <TitleSearch items={searchItems} label={searchLabel} />

  <section>
    <div class="section-head">
      <h2>Posts</h2>
      <p>{siteConfig.copy.postsSection}</p>
    </div>
    <div class="grid">
      {posts.map((entry) => (
        <article class="card">
          <p class="meta">{entry.data.date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" })}</p>
          <h3><a href={withBase(`posts/${entry.slug}/`)}>{entry.data.title}</a></h3>
          {entry.data.subtitle && <p class="card-subtitle">{entry.data.subtitle}</p>}
          <p>{entry.data.description}</p>
        </article>
      ))}
    </div>
  </section>

  {showExperiments && <section>
    <div class="section-head">
      <h2>Experiments</h2>
      <p>{siteConfig.copy.experimentsSection}</p>
    </div>
    <div class="grid">
      {experiments.map((experiment) => (
        <article class="card">
          <p class="meta">{experiment.data.status} &middot; {experiment.data.date.toLocaleDateString("en", { year: "numeric", month: "short", day: "numeric" })}</p>
          <h3><a href={withBase(experiment.data.link)}>{experiment.data.title}</a></h3>
          <p>{experiment.data.description}</p>
        </article>
      ))}
    </div>
  </section>}
</BaseLayout>
