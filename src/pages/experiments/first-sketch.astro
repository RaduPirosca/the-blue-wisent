---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="First Sketch" description="A starter page for a web programming experiment.">
  <article class="article">
    <header class="article-header">
      <p class="kicker">Experiment</p>
      <h1>First Sketch</h1>
      <p class="lede">
        &lt;BLABLA-FIRST-EXPERIMENT-INTRO-TO-BE-FILLED: explain what this experiment tries to do.&gt;
      </p>
    </header>
  </article>

  <section class="experiment-stage" aria-label="Experiment stage">
    <p>
      &lt;BLABLA-EXPERIMENT-STAGE-TO-BE-FILLED: replace this section with your HTML, canvas, Three.js mount point, or interactive UI.&gt;
    </p>
  </section>
</BaseLayout>
